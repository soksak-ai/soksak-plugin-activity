{
  "spec": "soksak-spec-plugin@0.0.1",
  "id": "soksak-plugin-activity",
  "name": {
    "en": "Activity",
    "ko": "활동"
  },
  "version": "0.0.1",
  "description": {
    "en": "The activity log in a project-window sidebar — the same hub stream the orchestrator feed shows. Entries whose spec carries tts are read aloud by the mascot (toggleable).",
    "ko": "프로젝트 창 사이드바의 활동로그 — 오케스트레이터 피드와 동일한 허브 스트림. 스펙에 tts가 실린 엔트리는 마스코트가 소리 내어 읽는다(토글 가능)."
  },
  "entry": "main.js",
  "permissions": [
    "ui",
    "commands",
    "data",
    "terminal",
    "fs:read"
  ],
  "consumes": [
    {
      "id": "soksak-spec-plugin-narration",
      "range": "0.0.1"
    }
  ],
  "contributes": {
    "views": [
      {
        "id": "log",
        "title": {
          "en": "Activity",
          "ko": "활동"
        },
        "icon": "📻",
        "placements": [
          "rail"
        ],
        "defaultPlacement": "rail"
      }
    ],
    "commands": [
      {
        "name": "ping",
        "title": {
          "en": "Pings the plugin",
          "ko": "플러그인 상태를 점검합니다"
        }
      },
      {
        "name": "list",
        "title": {
          "en": "Lists recent activity entries",
          "ko": "최근 활동 엔트리를 나열합니다"
        }
      },
      {
        "name": "mascot.toggle",
        "title": {
          "en": "Toggles character narration",
          "ko": "캐릭터 낭독을 켜고 끕니다"
        }
      }
    ],
    "nodes": [
      {
        "id": "mascot-toggle",
        "description": "Narration on/off button in the view bar (click flips mascot narration). data-node=\"mascot-toggle\"."
      }
    ]
  }
}
